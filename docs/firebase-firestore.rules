rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && request.auth.token.email == 'dono@reviveparts.com';
    }

    function isSameUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner() || isSameUser(userId);
      allow delete: if isOwner();
    }

    match /orders/{orderId} {
      allow read: if isOwner() || (signedIn() && resource.data.userUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userUid == request.auth.uid;
      allow update: if isOwner() || (
        signedIn()
        && resource.data.userUid == request.auth.uid
        && request.resource.data.userUid == resource.data.userUid
        && request.resource.data.status == resource.data.status
      );
      allow delete: if isOwner();

      match /events/{eventId} {
        allow read: if isOwner() || (
          signedIn()
          && get(/databases/$(database)/documents/orders/$(orderId)).data.userUid == request.auth.uid
        );
        allow create, update, delete: if signedIn();
      }
    }

    match /metadata/{document=**} {
      allow read, write: if signedIn();
    }
  }
}
